{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/judge-rubric.schema.json",
  "title": "Ralph judge rubric v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "weightPolicy": {
      "type": "string",
      "enum": ["strict-100", "normalize"]
    },
    "criteria": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "weight": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "blocking": {
            "default": false,
            "type": "boolean"
          }
        },
        "required": ["criterion", "description", "weight", "blocking"],
        "additionalProperties": false
      }
    }
  },
  "required": ["schemaVersion", "weightPolicy", "criteria"],
  "additionalProperties": false
}
