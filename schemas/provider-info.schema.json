{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/provider-info.schema.json",
  "title": "Ralph provider information v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["available", "unavailable", "unknown", "deprecated"]
    },
    "access": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["api", "subscription"]
      }
    },
    "credentialMethods": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "api-key",
              "environment",
              "oauth-browser",
              "device-code",
              "subscription-session",
              "existing-session",
              "external-cli"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "access": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["api", "subscription"]
            }
          },
          "interactive": {
            "type": "boolean"
          }
        },
        "required": ["method", "label", "access", "interactive"],
        "additionalProperties": false
      }
    },
    "catalogSource": {
      "type": "string",
      "minLength": 1
    },
    "catalogUpdatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "name",
    "status",
    "access",
    "credentialMethods",
    "catalogSource",
    "catalogUpdatedAt"
  ],
  "additionalProperties": false
}
