{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/task-record.schema.json",
  "title": "Ralph task record v1",
  "type": "object",
  "properties": {
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "documentId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "eligible",
        "active",
        "verifying",
        "evaluating",
        "retryable_failed",
        "interrupted",
        "blocked",
        "rejected",
        "cancelled",
        "completed",
        "completed_with_override"
      ]
    },
    "markerContentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "activeAttemptId": {
      "type": "string",
      "minLength": 1
    },
    "completion": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "revision_required", "blocked", "overridden"]
        },
        "deterministicPassed": {
          "type": "boolean"
        },
        "evaluationMode": {
          "type": "string",
          "enum": ["none", "external", "self", "manual"]
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "threshold": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "severityRulesPassed": {
          "type": "boolean"
        },
        "evidenceBundleId": {
          "type": "string",
          "minLength": 1
        },
        "assessmentId": {
          "type": "string",
          "minLength": 1
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "decidedBy": {
          "type": "string",
          "const": "ralph-policy"
        },
        "decidedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        }
      },
      "required": [
        "status",
        "deterministicPassed",
        "evaluationMode",
        "evidenceBundleId",
        "reasons",
        "decidedBy",
        "decidedAt"
      ],
      "additionalProperties": false
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    }
  },
  "required": ["runId", "taskId", "documentId", "status", "markerContentHash", "updatedAt"],
  "additionalProperties": false
}
