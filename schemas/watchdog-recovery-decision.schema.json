{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/watchdog-recovery-decision.schema.json",
  "title": "Ralph watchdog recovery decision v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "action": {
      "type": "string",
      "enum": ["none", "notify", "cancel", "restart-attempt", "stop-run"]
    },
    "configuredAction": {
      "type": "string",
      "enum": ["notify", "cancel", "restart-attempt", "stop-run"]
    },
    "cause": {
      "type": "string",
      "enum": [
        "none",
        "disabled",
        "settled",
        "suspect",
        "stalled",
        "hard-timeout",
        "restart-budget-exhausted"
      ]
    },
    "phase": {
      "type": "string",
      "enum": ["model-call", "tool", "gate", "judge", "child", "integration"]
    },
    "state": {
      "type": "string",
      "enum": ["healthy", "quiet", "slow", "suspect", "stalled", "recovered"]
    },
    "requiresDiagnosticSnapshot": {
      "type": "boolean"
    },
    "requestProtocolPing": {
      "type": "boolean"
    },
    "gracefulCancelFirst": {
      "type": "boolean"
    },
    "forceKillAfterGrace": {
      "type": "boolean"
    },
    "preserveTask": {
      "type": "boolean",
      "const": true
    },
    "preserveDiff": {
      "type": "boolean",
      "const": true
    },
    "resumable": {
      "type": "boolean",
      "const": true
    },
    "consumesJudgeRevision": {
      "type": "boolean",
      "const": false
    },
    "watchdogRestartDelta": {
      "anyOf": [
        {
          "type": "number",
          "const": 0
        },
        {
          "type": "number",
          "const": 1
        }
      ]
    },
    "budgetBefore": {
      "type": "object",
      "properties": {
        "used": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "maximum": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "remaining": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "exhausted": {
          "type": "boolean"
        }
      },
      "required": ["used", "maximum", "remaining", "exhausted"],
      "additionalProperties": false
    },
    "budgetAfter": {
      "type": "object",
      "properties": {
        "used": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "maximum": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "remaining": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "exhausted": {
          "type": "boolean"
        }
      },
      "required": ["used", "maximum", "remaining", "exhausted"],
      "additionalProperties": false
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "watchdog-disabled",
          "control-heartbeat-fresh",
          "control-heartbeat-missing",
          "progress-recent",
          "progress-quiet",
          "progress-slow",
          "progress-stale",
          "process-alive",
          "process-dead",
          "process-unknown",
          "process-active",
          "process-idle",
          "provider-pending",
          "provider-idle",
          "provider-unknown",
          "provider-stream-open",
          "provider-stream-quiet",
          "provider-retry-after",
          "child-heartbeat-fresh",
          "child-heartbeat-missing",
          "settlement-running",
          "settlement-finished",
          "settlement-unknown",
          "deadline-within-limit",
          "phase-deadline-exceeded",
          "hard-timeout-exceeded",
          "negative-quorum",
          "insufficient-negative-signals",
          "awaiting-confirmation",
          "recovered-signals",
          "restart-budget-exhausted"
        ]
      }
    }
  },
  "required": [
    "schemaVersion",
    "action",
    "configuredAction",
    "cause",
    "phase",
    "state",
    "requiresDiagnosticSnapshot",
    "requestProtocolPing",
    "gracefulCancelFirst",
    "forceKillAfterGrace",
    "preserveTask",
    "preserveDiff",
    "resumable",
    "consumesJudgeRevision",
    "watchdogRestartDelta",
    "budgetBefore",
    "budgetAfter",
    "reasons"
  ],
  "additionalProperties": false
}
