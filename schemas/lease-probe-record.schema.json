{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/lease-probe-record.schema.json",
  "title": "Ralph durable lease owner probe record v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "leaseId": {
      "type": "string",
      "minLength": 1
    },
    "observerInstanceId": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "status": {
      "type": "string",
      "enum": ["alive", "dead", "identity-mismatch", "unreachable"]
    },
    "expectedProcessStartToken": {
      "type": "string",
      "minLength": 1
    },
    "observedProcessStartToken": {
      "type": "string",
      "minLength": 1
    },
    "observedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "leaseId",
    "observerInstanceId",
    "sequence",
    "status",
    "expectedProcessStartToken",
    "observedAt",
    "reason"
  ],
  "additionalProperties": false
}
