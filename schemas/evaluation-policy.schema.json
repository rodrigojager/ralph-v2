{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/evaluation-policy.schema.json",
  "title": "Ralph evaluation policy v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "mode": {
      "type": "string",
      "enum": ["deterministic-only", "external", "self", "manual"]
    },
    "threshold": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "maxRevisionAttempts": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "judgeCallRetries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "onJudgeUnavailable": {
      "type": "string",
      "enum": ["deterministic", "pause", "fail"]
    },
    "blockingSeverities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["info", "minor", "major", "critical"]
      }
    },
    "exhaustedPolicy": {
      "type": "string",
      "enum": ["manual-review", "fail", "stop-run"]
    },
    "rubric": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 1
        },
        "weightPolicy": {
          "type": "string",
          "enum": ["strict-100", "normalize"]
        },
        "criteria": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "criterion": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "weight": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "blocking": {
                "default": false,
                "type": "boolean"
              }
            },
            "required": ["criterion", "description", "weight", "blocking"],
            "additionalProperties": false
          }
        }
      },
      "required": ["schemaVersion", "weightPolicy", "criteria"],
      "additionalProperties": false
    }
  },
  "required": [
    "schemaVersion",
    "mode",
    "threshold",
    "maxRevisionAttempts",
    "judgeCallRetries",
    "onJudgeUnavailable",
    "blockingSeverities",
    "exhaustedPolicy",
    "rubric"
  ],
  "additionalProperties": false
}
