{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/model-info.schema.json",
  "title": "Ralph model information v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "provider": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["available", "unavailable", "unknown", "deprecated"]
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "input": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["text", "image", "file"]
          }
        },
        "tools": {
          "type": "boolean"
        },
        "toolStreaming": {
          "type": "boolean"
        },
        "reasoning": {
          "type": "boolean"
        },
        "structuredOutput": {
          "type": "boolean"
        },
        "usage": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["input", "output", "reasoning", "cache-read", "cache-write", "cost"]
          }
        }
      },
      "required": ["input", "tools", "toolStreaming", "reasoning", "structuredOutput", "usage"],
      "additionalProperties": false
    },
    "limits": {
      "type": "object",
      "properties": {
        "context": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "output": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "parameters": {
            "type": "object",
            "propertyNames": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^\\S+$"
            },
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        "required": ["id", "name", "parameters"],
        "additionalProperties": false
      }
    },
    "price": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["available", "unavailable"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "appliesTo": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["api", "subscription"]
          }
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "unit": {
          "type": "string",
          "const": "per-million-tokens"
        },
        "input": {
          "type": "number",
          "minimum": 0
        },
        "output": {
          "type": "number",
          "minimum": 0
        },
        "reasoning": {
          "type": "number",
          "minimum": 0
        },
        "cacheRead": {
          "type": "number",
          "minimum": 0
        },
        "cacheWrite": {
          "type": "number",
          "minimum": 0
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["id", "status", "source", "capturedAt", "appliesTo"],
      "additionalProperties": false
    },
    "access": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["api", "subscription"]
      }
    },
    "catalogSource": {
      "type": "string",
      "minLength": 1
    },
    "catalogUpdatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    }
  },
  "required": [
    "schemaVersion",
    "provider",
    "id",
    "name",
    "status",
    "capabilities",
    "limits",
    "variants",
    "price",
    "access",
    "catalogSource",
    "catalogUpdatedAt"
  ],
  "additionalProperties": false
}
