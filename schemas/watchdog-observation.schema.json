{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/watchdog-observation.schema.json",
  "title": "Ralph watchdog observation v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "probeId": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": ["model-call", "tool", "gate", "judge", "child", "integration"]
    },
    "observedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "monotonicMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "phaseStartedMonotonicMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "lastControlHeartbeatAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "lastControlHeartbeatMonotonicMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "lastProgressAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "lastProgressMonotonicMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "lastProcessProbeAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "lastProcessProbeMonotonicMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "lastChildHeartbeatAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "lastChildHeartbeatMonotonicMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "processAlive": {
      "default": "unknown",
      "type": "string",
      "enum": ["yes", "no", "unknown"]
    },
    "processActivity": {
      "default": "unknown",
      "type": "string",
      "enum": ["yes", "no", "unknown"]
    },
    "providerPending": {
      "default": "unknown",
      "type": "string",
      "enum": ["yes", "no", "unknown"]
    },
    "providerStreamOpen": {
      "default": "unknown",
      "type": "string",
      "enum": ["yes", "no", "unknown"]
    },
    "providerRetryAfterMonotonicMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "settlement": {
      "default": "unknown",
      "type": "string",
      "enum": ["running", "settled", "unknown"]
    },
    "phaseDeadlineMonotonicMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "hardDeadlineMonotonicMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "schemaVersion",
    "probeId",
    "phase",
    "observedAt",
    "monotonicMs",
    "phaseStartedMonotonicMs",
    "processAlive",
    "processActivity",
    "providerPending",
    "providerStreamOpen",
    "settlement"
  ],
  "additionalProperties": false
}
