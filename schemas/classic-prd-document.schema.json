{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/classic-prd-document.schema.json",
  "title": "Ralph classic PRD compatibility document v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "sourceFormat": {
      "type": "string",
      "enum": ["markdown", "yaml", "json"]
    },
    "file": {
      "type": "string",
      "minLength": 1
    },
    "contentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "contextBeforeTasks": {
      "type": "string"
    },
    "preservedLegacyContent": {
      "type": "string"
    },
    "frontmatter": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "$ref": "#/$defs/__schema0"
      }
    },
    "tasks": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ordinal": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "text": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "completed", "skipped-for-review"]
          },
          "line": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "column": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "markerByteOffset": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "indentation": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "group": {
            "type": "string",
            "minLength": 1
          },
          "dependsOnGroups": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "acceptanceCriteria": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "filesAllowed": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "gates": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "priority": {
            "type": "string",
            "minLength": 1
          },
          "complexity": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "ordinal",
          "text",
          "status",
          "line",
          "column",
          "indentation",
          "dependsOnGroups",
          "acceptanceCriteria",
          "filesAllowed",
          "gates",
          "notes"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion",
    "sourceFormat",
    "file",
    "contentHash",
    "contextBeforeTasks",
    "preservedLegacyContent",
    "frontmatter",
    "tasks"
  ],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      ]
    }
  }
}
