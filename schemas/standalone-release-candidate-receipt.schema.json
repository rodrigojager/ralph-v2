                  "bun-windows-x64-baseline",
                  "bun-windows-arm64",
                  "bun-linux-x64-baseline",
                  "bun-linux-arm64",
                  "bun-darwin-x64",
                  "bun-darwin-arm64"
                ]
              },
              "evidenceStatus": {
                "type": "string",
                "const": "built-not-tested"
              },
              "launcher": {
                "type": "object",
                "properties": {
