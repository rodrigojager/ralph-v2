            "url": {
              "type": "string",
              "format": "uri"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "sizeBytes": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 4294967296
            },
            "mediaType": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            }
          },
          "required": ["path", "sha256", "sizeBytes", "mediaType"],
          "additionalProperties": false
        },
        "thirdPartyNotices": {
          "type": "object",
