{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/marker-update.schema.json",
  "title": "Ralph PRD marker update result v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "file": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "previousStatus": {
      "type": "string",
      "enum": ["pending", "active", "completed"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "active", "completed"]
    },
    "previousContentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "contentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "markerByteOffset": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "changed": {
      "type": "boolean"
    },
    "reparsed": {
      "type": "boolean",
      "const": true
    }
  },
  "required": [
    "schemaVersion",
    "file",
    "taskId",
    "previousStatus",
    "status",
    "previousContentHash",
    "contentHash",
    "markerByteOffset",
    "changed",
    "reparsed"
  ],
  "additionalProperties": false
}
