{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/gate-result.schema.json",
  "title": "Ralph gate result v1",
  "type": "object",
  "properties": {
    "gateId": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "blocking": {
      "type": "boolean"
    },
    "skipPolicy": {
      "type": "string",
      "enum": ["required", "optional", "allowed-to-skip", "never-run"]
    },
    "criterionIds": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "timeout",
        "error",
        "skipped_by_cli",
        "skipped_by_policy",
        "not_applicable",
        "unavailable"
      ]
    },
    "command": {
      "type": "object",
      "properties": {
        "executable": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        },
        "environmentRefs": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "shell": {
          "anyOf": [
            {
              "type": "boolean",
              "const": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["powershell", "cmd", "sh", "bash", "custom"]
                },
                "executable": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": ["kind"],
              "additionalProperties": false
            }
          ]
        },
        "timeoutMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "successExitCodes": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          }
        },
        "outputLimitBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": ["executable", "args", "timeoutMs", "successExitCodes", "outputLimitBytes"],
      "additionalProperties": false
    },
    "exitCode": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "attempts": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "outputRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stdoutBytes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "stderrBytes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "outputTruncated": {
      "type": "boolean"
    },
    "rawOutputTruncated": {
      "type": "boolean"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["gateId", "category", "blocking", "status", "durationMs", "outputRefs"],
  "additionalProperties": false
}
