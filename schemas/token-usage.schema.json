{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/token-usage.schema.json",
  "title": "Ralph normalized token usage v1",
  "type": "object",
  "properties": {
    "input": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "inputNonCached": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "cacheRead": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "cacheWrite": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "output": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "reasoning": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "total": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "cost": {
      "type": "object",
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "priceSnapshotId": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "enum": ["reported", "derived", "estimated"]
        }
      },
      "required": ["amount", "currency", "priceSnapshotId"],
      "additionalProperties": false
    },
    "source": {
      "type": "string",
      "enum": ["reported", "derived", "estimated", "unavailable"]
    },
    "semantics": {
      "type": "string",
      "enum": ["delta", "cumulative", "final"]
    },
    "providerRawRef": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["source", "semantics"],
  "additionalProperties": false
}
