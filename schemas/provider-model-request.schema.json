{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/provider-model-request.schema.json",
  "title": "Ralph provider model request v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "callId": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S+$"
        },
        "variant": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
        }
      },
      "required": ["provider", "model"],
      "additionalProperties": false
    },
    "messages": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["role", "content"],
        "additionalProperties": false
      }
    },
    "input": {
      "minItems": 1,
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "role": {
                "type": "string",
                "enum": ["system", "user", "assistant"]
              },
              "content": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "const": "message"
              }
            },
            "required": ["role", "content", "type"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "function-call"
              },
              "itemId": {
                "type": "string",
                "minLength": 1
              },
              "callId": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128,
                "pattern": "^[A-Za-z_][A-Za-z0-9_.:-]*$"
              },
              "argumentsJson": {
                "type": "string",
                "minLength": 2
              },
              "input": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "$ref": "#/$defs/__schema0"
                }
              }
            },
            "required": ["type", "itemId", "callId", "name", "argumentsJson", "input"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "function-call-output"
              },
              "callId": {
                "type": "string",
                "minLength": 1
              },
              "output": {
                "type": "string"
              }
            },
            "required": ["type", "callId", "output"],
            "additionalProperties": false
          }
        ]
      }
    },
    "tools": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z_][A-Za-z0-9_.:-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "inputSchema": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "$ref": "#/$defs/__schema0"
            }
          }
        },
        "required": ["name", "description", "inputSchema"],
        "additionalProperties": false
      }
    },
    "parameters": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^\\S+$"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "maxOutputTokens": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "responseFormat": {
      "type": "string",
      "enum": ["text", "json"]
    },
    "responseSchema": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "schema": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        },
        "strict": {
          "type": "boolean",
          "const": true
        }
      },
      "required": ["name", "schema", "strict"],
      "additionalProperties": false
    }
  },
  "required": ["schemaVersion", "callId", "model", "tools", "parameters", "responseFormat"],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      ]
    }
  }
}
