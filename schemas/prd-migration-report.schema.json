{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/prd-migration-report.schema.json",
  "title": "Ralph PRD migration report v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "output": {
      "type": "string",
      "minLength": 1
    },
    "detected": {
      "type": "string",
      "const": "classic"
    },
    "taskCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "lossless": {
      "type": "boolean"
    },
    "notices": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error"]
          },
          "kind": {
            "type": "string",
            "enum": ["direct", "inferred", "promoted", "dropped", "semantic-change"]
          },
          "source": {
            "type": "object",
            "properties": {
              "file": {
                "type": "string",
                "minLength": 1
              },
              "line": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "column": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "field": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "$ref": "#/$defs/__schema0"
              }
            },
            "required": ["file", "field"],
            "additionalProperties": false
          },
          "target": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "$ref": "#/$defs/__schema0"
              }
            },
            "required": ["field"],
            "additionalProperties": false
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["code", "severity", "kind", "source", "reason"],
        "additionalProperties": false
      }
    }
  },
  "required": ["schemaVersion", "source", "output", "detected", "taskCount", "lossless", "notices"],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      ]
    }
  }
}
