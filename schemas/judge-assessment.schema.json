{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/judge-assessment.schema.json",
  "title": "Ralph judge assessment v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["external", "self"]
    },
    "profileSnapshot": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": ["executor", "judge"]
        },
        "backend": {
          "type": "string",
          "enum": ["fake", "embedded", "external-cli"]
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "variant": {
          "type": "string",
          "minLength": 1
        },
        "contentHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "required": ["id", "role", "backend", "provider", "model", "contentHash"],
      "additionalProperties": false
    },
    "evidenceBundleId": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "adequate": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["info", "minor", "major", "critical"]
          },
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": ["severity", "message", "evidenceRefs"],
        "additionalProperties": false
      }
    },
    "missingEvidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "criterionScores": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["criterion", "score"],
        "additionalProperties": false
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rawResponseRef": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "profileSnapshot",
    "evidenceBundleId",
    "score",
    "summary",
    "adequate",
    "problems",
    "missingEvidence",
    "recommendations",
    "criterionScores",
    "createdAt"
  ],
  "additionalProperties": false
}
