{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/watchdog-profile.schema.json",
  "title": "Ralph resolved watchdog profile v1",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean"
    },
    "heartbeatIntervalMs": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "heartbeatGraceMs": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "quietAfterMs": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "slowAfterMs": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "suspectAfterMs": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "hardTimeoutMs": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "probeIntervalMs": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "confirmations": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "action": {
      "type": "string",
      "enum": ["notify", "cancel", "restart-attempt", "stop-run"]
    },
    "maxRestarts": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "phases": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "enum": ["model-call", "tool", "gate", "judge", "child", "integration"]
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "heartbeatIntervalMs": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "heartbeatGraceMs": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "quietAfterMs": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "slowAfterMs": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "suspectAfterMs": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "hardTimeoutMs": {
            "anyOf": [
              {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              {
                "type": "null"
              }
            ]
          },
          "probeIntervalMs": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "confirmations": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "action": {
            "type": "string",
            "enum": ["notify", "cancel", "restart-attempt", "stop-run"]
          },
          "maxRestarts": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": [
    "enabled",
    "heartbeatIntervalMs",
    "heartbeatGraceMs",
    "quietAfterMs",
    "slowAfterMs",
    "suspectAfterMs",
    "probeIntervalMs",
    "confirmations",
    "action",
    "maxRestarts",
    "phases"
  ],
  "additionalProperties": false
}
