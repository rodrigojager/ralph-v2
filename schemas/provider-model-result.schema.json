{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/provider-model-result.schema.json",
  "title": "Ralph normalized provider model result v1",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "callId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["succeeded", "failed", "cancelled"]
    },
    "finishReason": {
      "type": "string",
      "enum": ["stop", "length", "tool-call", "content-filter", "error", "cancelled", "unknown"]
    },
    "text": {
      "type": "string"
    },
    "reasoningSummary": {
      "type": "string"
    },
    "usage": {
      "type": "object",
      "properties": {
        "input": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "inputNonCached": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheRead": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheWrite": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "output": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "reasoning": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "total": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cost": {
          "type": "object",
          "properties": {
            "amount": {
              "type": "number",
              "minimum": 0
            },
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            "priceSnapshotId": {
              "type": "string",
              "minLength": 1
            },
            "source": {
              "type": "string",
              "enum": ["reported", "derived", "estimated"]
            }
          },
          "required": ["amount", "currency", "priceSnapshotId"],
          "additionalProperties": false
        },
        "source": {
          "type": "string",
          "enum": ["reported", "derived", "estimated", "unavailable"]
        },
        "semantics": {
          "type": "string",
          "enum": ["delta", "cumulative", "final"]
        },
        "providerRawRef": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["source", "semantics"],
      "additionalProperties": false
    },
    "toolCalls": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "itemId": {
            "type": "string",
            "minLength": 1
          },
          "callId": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z_][A-Za-z0-9_.:-]*$"
          },
          "argumentsJson": {
            "type": "string",
            "minLength": 2
          },
          "input": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "$ref": "#/$defs/__schema0"
            }
          }
        },
        "required": ["itemId", "callId", "name", "argumentsJson", "input"],
        "additionalProperties": false
      }
    }
  },
  "required": ["schemaVersion", "callId", "status", "finishReason", "usage", "toolCalls"],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      ]
    }
  }
}
