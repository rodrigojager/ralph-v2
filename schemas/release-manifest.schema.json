{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/release-manifest.schema.json",
  "title": "Ralph release manifest v2",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 2
    },
    "product": {
      "type": "string",
      "const": "ralph"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "channel": {
      "type": "string",
      "enum": ["dev", "nightly", "beta", "stable"]
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "source": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "fingerprintSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "required": ["repository", "commit", "fingerprintSha256"],
      "additionalProperties": false
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "minimumWorkspaceSchema": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "maximumWorkspaceSchema": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "minimumLauncherSchema": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "maximumLauncherSchema": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "downgradeSafeThrough": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        }
      },
      "required": [
        "minimumWorkspaceSchema",
        "maximumWorkspaceSchema",
        "minimumLauncherSchema",
        "maximumLauncherSchema"
      ],
      "additionalProperties": false
    },
    "supportPolicy": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 1
        },
        "product": {
          "type": "string",
          "const": "ralph"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "channel": {
          "type": "string",
          "enum": ["dev", "nightly", "beta", "stable"]
        },
        "matrix": {
          "minItems": 6,
          "maxItems": 6,
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "target": {
                    "type": "string",
                    "enum": [
                      "bun-windows-x64-baseline",
                      "bun-windows-arm64",
                      "bun-linux-x64-baseline",
                      "bun-linux-arm64",
                      "bun-darwin-x64",
                      "bun-darwin-arm64"
                    ]
                  },
                  "status": {
                    "type": "string",
                    "const": "included"
                  },
                  "capabilities": {
                    "type": "object",
                    "properties": {
                      "installControlStateDurability": {
                        "type": "object",
                        "properties": {
                          "fileSync": {
                            "type": "string",
                            "const": "fsync-before-rename"
                          },
                          "directorySync": {
                            "type": "string",
                            "enum": ["fsync-after-rename", "unsupported-file-sync-only"]
                          },
                          "guarantee": {
                            "type": "string",
                            "enum": ["full", "reduced"]
                          }
                        },
                        "required": ["fileSync", "directorySync", "guarantee"],
                        "additionalProperties": false
                      }
                    },
                    "required": ["installControlStateDurability"],
                    "additionalProperties": false
                  },
                  "limitations": {
                    "maxItems": 64,
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 2000
                    }
                  }
                },
                "required": ["target", "status", "capabilities", "limitations"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "target": {
                    "type": "string",
                    "enum": [
                      "bun-windows-x64-baseline",
                      "bun-windows-arm64",
                      "bun-linux-x64-baseline",
                      "bun-linux-arm64",
                      "bun-darwin-x64",
                      "bun-darwin-arm64"
                    ]
                  },
                  "status": {
                    "type": "string",
                    "const": "not-promoted"
                  },
                  "capabilities": {
                    "type": "object",
                    "properties": {
                      "installControlStateDurability": {
                        "type": "object",
                        "properties": {
                          "fileSync": {
                            "type": "string",
                            "const": "fsync-before-rename"
                          },
                          "directorySync": {
                            "type": "string",
                            "enum": ["fsync-after-rename", "unsupported-file-sync-only"]
                          },
                          "guarantee": {
                            "type": "string",
                            "enum": ["full", "reduced"]
                          }
                        },
                        "required": ["fileSync", "directorySync", "guarantee"],
                        "additionalProperties": false
                      }
                    },
                    "required": ["installControlStateDurability"],
                    "additionalProperties": false
                  },
                  "reason": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 2000
                  }
                },
                "required": ["target", "status", "capabilities", "reason"],
                "additionalProperties": false
              }
            ]
          }
        }
      },
      "required": ["schemaVersion", "product", "version", "channel", "matrix"],
      "additionalProperties": false
    },
    "supportPolicySha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifacts": {
      "minItems": 1,
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string",
            "enum": [
              "bun-windows-x64-baseline",
              "bun-windows-arm64",
              "bun-linux-x64-baseline",
              "bun-linux-arm64",
              "bun-darwin-x64",
              "bun-darwin-arm64"
            ]
          },
          "evidenceStatus": {
            "type": "string",
            "enum": ["tested", "built-not-tested", "not-evidenced"]
          },
          "launcher": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "sizeBytes": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 4294967296
              },
              "mediaType": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              }
            },
            "required": ["path", "sha256", "sizeBytes", "mediaType"],
            "additionalProperties": false
          },
          "launcherBuildMetadata": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "sizeBytes": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 4294967296
              },
              "mediaType": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              }
            },
            "required": ["path", "sha256", "sizeBytes", "mediaType"],
            "additionalProperties": false
          },
          "executable": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "sizeBytes": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 4294967296
              },
              "mediaType": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              }
            },
            "required": ["path", "sha256", "sizeBytes", "mediaType"],
            "additionalProperties": false
          },
          "buildMetadata": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "sizeBytes": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 4294967296
              },
              "mediaType": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              }
            },
            "required": ["path", "sha256", "sizeBytes", "mediaType"],
            "additionalProperties": false
          },
          "archive": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "sizeBytes": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 4294967296
              },
              "mediaType": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              }
            },
            "required": ["path", "sha256", "sizeBytes", "mediaType"],
            "additionalProperties": false
          },
          "limitations": {
            "default": [],
            "maxItems": 64,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 2000
            }
          }
        },
        "required": [
          "target",
          "evidenceStatus",
          "launcher",
          "launcherBuildMetadata",
          "executable",
          "buildMetadata",
          "limitations"
        ],
        "additionalProperties": false
      }
    },
    "license": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4294967296
        },
        "mediaType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": ["path", "sha256", "sizeBytes", "mediaType"],
      "additionalProperties": false
    },
    "thirdPartyNotices": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4294967296
        },
        "mediaType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": ["path", "sha256", "sizeBytes", "mediaType"],
      "additionalProperties": false
    },
    "sbom": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4294967296
        },
        "mediaType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": ["path", "sha256", "sizeBytes", "mediaType"],
      "additionalProperties": false
    },
    "skill": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4294967296
        },
        "mediaType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": ["path", "sha256", "sizeBytes", "mediaType"],
      "additionalProperties": false
    },
    "checksums": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4294967296
        },
        "mediaType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": ["path", "sha256", "sizeBytes", "mediaType"],
      "additionalProperties": false
    },
    "promotionRecord": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4294967296
        },
        "mediaType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": ["path", "sha256", "sizeBytes", "mediaType"],
      "additionalProperties": false
    },
    "signature": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "const": "unavailable"
            },
            "reason": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1000
            }
          },
          "required": ["status", "reason"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "const": "present"
            },
            "kind": {
              "type": "string",
              "enum": ["cosign", "minisign", "gpg", "sigstore-bundle"]
            },
            "identity": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1000
            },
            "signedManifestSha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "payload": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "maximumSizeBytes": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 67108864
                },
                "mediaType": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 128,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]*\\/[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]*$"
                }
              },
              "required": ["path", "maximumSizeBytes", "mediaType"],
              "additionalProperties": false
            }
          },
          "required": ["status", "kind", "identity", "signedManifestSha256", "payload"],
          "additionalProperties": false
        }
      ]
    }
  },
  "required": [
    "schemaVersion",
    "product",
    "version",
    "channel",
    "publishedAt",
    "source",
    "compatibility",
    "supportPolicy",
    "supportPolicySha256",
    "artifacts",
    "license",
    "thirdPartyNotices",
    "sbom",
    "skill",
    "checksums",
    "signature"
  ],
  "additionalProperties": false
}
