          "runtimeEvidence": {
            "minItems": 1,
            "maxItems": 16,
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$"
