      "properties": {
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "fingerprintSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "required": ["repository", "commit", "fingerprintSha256"],
      "additionalProperties": false
    },
    "support": {
      "type": "object",
      "properties": {
        "licenseSha256": {
          "type": "string",
