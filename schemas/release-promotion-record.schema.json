        "thirdPartyNoticesSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "sbomSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "skillArtifactSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
