  "$id": "https://rodrigojager.github.io/ralph-v2/schemas/v2/release-promotion-record.schema.json",
  "title": "Ralph release promotion record v3",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 3
    },
    "product": {
      "type": "string",
      "const": "ralph"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
